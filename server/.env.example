NODE_ENV=production
PORT=8080
API_PORT=8080
API_BODY_LIMIT=2mb
CORS_ORIGIN=https://your-jaad-cloud-domain.example

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=***REPLACE_IN_PRODUCTION***
SUPABASE_SERVICE_ROLE_KEY=***REPLACE_IN_PRODUCTION***
SUPABASE_JWT_SECRET=***REPLACE_IN_PRODUCTION_IF_USED***
JWT_SECRET=***REPLACE_IN_PRODUCTION_IF_USED***

# Used only by server/scripts/apply-migrations.js.
DATABASE_URL=postgresql://postgres:***REPLACE_IN_PRODUCTION***@db.project.supabase.co:5432/postgres
DATABASE_SSL=true

# Required for server-side ZATCA key encryption/decryption and Java signer calls.
ZATCA_SECRET_KEY=***REPLACE_WITH_STRONG_32_BYTE_SECRET***
ZATCA_DEVICE_KEY_ENCRYPTION_SECRET=***REPLACE_WITH_STRONG_32_BYTE_SECRET***
ZATCA_SIGNING_SERVICE_URL=http://127.0.0.1:8081
ZATCA_SIGNING_SERVICE_SECRET=***REPLACE_WITH_SHARED_SIGNING_SECRET***
SIGNING_SERVICE_SECRET=***SAME_AS_ZATCA_SIGNING_SERVICE_SECRET_FOR_DOCKER_ENV_FILE***
ZATCA_SDK_VERSION=4.0.0
ZATCA_AUTO_RUNNER_ENABLED=false
ZATCA_AUTO_RUNNER_INTERVAL_MS=60000
ZATCA_AUTO_RUNNER_BATCH_SIZE=10

# Used by /api/public/* HMAC verification.
PUBLIC_WEBHOOK_HMAC_SECRET=***REPLACE_WITH_WEBHOOK_HMAC_SECRET***

# GitHub Actions repository secrets, configure in GitHub UI rather than this file:
# HOST=***HOSTINGER_VPS_IP_OR_HOSTNAME***
# USERNAME=***SSH_USERNAME***
# PORT=22
# SSH_KEY=***PRIVATE_DEPLOY_KEY***
