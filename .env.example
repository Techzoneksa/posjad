NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Next.js frontend
FRONTEND_PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=***REPLACE_IN_PRODUCTION***
# Accepted legacy/public aliases used by the deployment workflow as fallbacks:
SUPABASE_PUBLISHABLE_KEY=***REPLACE_IN_PRODUCTION***
SUPABASE_ANON_KEY=***REPLACE_IN_PRODUCTION***
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=***REPLACE_IN_PRODUCTION***

# Server-side values used during Next.js build only when server modules are compiled.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=***REPLACE_IN_PRODUCTION***

# Public deployment origin
APP_BASE_URL=https://pos.example.com
NEXT_PUBLIC_APP_URL=https://pos.example.com

# GitHub Actions repository secrets, configure in GitHub UI rather than this file:
# HOST=***HOSTINGER_VPS_IP_OR_HOSTNAME***
# USERNAME=***SSH_USERNAME***
# PORT=22
# SSH_KEY=***PRIVATE_DEPLOY_KEY***
